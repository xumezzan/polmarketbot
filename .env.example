APP_NAME=Polymarket News Bot
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_ECHO=false
LOG_LEVEL=INFO

POSTGRES_DB=polymarket
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=polymarket
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

NEWS_FETCH_MODE=stub
NEWS_API_BASE_URL=https://newsapi.org/v2
NEWS_QUERY=(bitcoin OR ethereum OR crypto OR ETF OR "Federal Reserve" OR inflation OR tariff OR recession OR election) NOT (auction OR "No Reserve" OR "Bring a Trailer")
NEWS_LANGUAGE=en
NEWS_PAGE_SIZE=20
NEWS_MAX_PAGES=5
NEWS_LOOKBACK_HOURS=24
NEWS_MIN_FETCH_INTERVAL_MINUTES=30
NEWS_ENABLE_FALLBACK_LOOKBACK=true
NEWS_FALLBACK_LOOKBACK_HOURS=72
NEWS_SEARCH_IN=title,description
NEWS_SORT_BY=relevancy
NEWS_EXCLUDE_DOMAINS=bringatrailer.com
NEWS_API_TIMEOUT_SECONDS=15
NEWS_RELEVANCE_FILTER_ENABLED=true
NEWS_RELEVANCE_MIN_HITS=2
NEWS_RATE_LIMIT_COOLDOWN_MINUTES=30
NEWS_FALLBACK_MODE=
NEWS_API_KEY=

RSS_FEED_URLS=
RSS_ALLOWED_SOURCES=
RSS_BLOCKED_SOURCES=
RSS_REQUEST_TIMEOUT_SECONDS=15
RSS_MAX_ITEMS_PER_FEED=20

LLM_MODE=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_INPUT_COST_PER_1M_TOKENS=0.75
OPENAI_OUTPUT_COST_PER_1M_TOKENS=4.50
OPENAI_TIMEOUT_SECONDS=30
OPENAI_TEMPERATURE=0
OPENAI_MAX_COMPLETION_TOKENS=300
LLM_MAX_CONTENT_CHARS=4000

MARKET_FETCH_MODE=stub
GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
GAMMA_MARKETS_PAGE_SIZE=200
GAMMA_MARKETS_MAX_PAGES=25
GAMMA_FETCH_ACTIVE_ONLY=true
GAMMA_FETCH_CLOSED=false
GAMMA_REQUEST_TIMEOUT_SECONDS=20
MARKET_TOP_N=5
MARKET_MATCH_STRATEGY=keyword
MARKET_MATCH_MIN_SCORE=0.15
MARKET_MATCH_EXACT_WEIGHT=0.35
MARKET_MATCH_QUESTION_WEIGHT=0.35
MARKET_MATCH_SLUG_WEIGHT=0.15
MARKET_MATCH_EVENT_WEIGHT=0.10
MARKET_MATCH_LIQUIDITY_WEIGHT=0.05
MARKET_CORRELATION_FILTER_ENABLED=true
MARKET_CORRELATION_JACCARD_THRESHOLD=0.75
MARKET_CORRELATION_BLOCK_SAME_EVENT=true

SIGNAL_ACTIONABLE_EDGE_THRESHOLD=0.07
SIGNAL_ACTIONABLE_CONFIDENCE_THRESHOLD=0.70
SIGNAL_ACTIONABLE_RELEVANCE_THRESHOLD=0.65
SIGNAL_WATCHLIST_EDGE_THRESHOLD=0.01

RISK_MIN_CONFIDENCE=0.70
RISK_MIN_RELEVANCE=0.65
RISK_MAX_NEWS_AGE_MINUTES=360
RISK_ENABLE_EXTENDED_NEWS_AGE_WINDOW=false
RISK_EXTENDED_MAX_NEWS_AGE_MINUTES=1800
RISK_EXTENDED_NEWS_AGE_SIZE_MULTIPLIER=0.50
RISK_MIN_MARKET_LIQUIDITY=10000
RISK_PRICED_IN_EDGE_THRESHOLD=0.03
RISK_MIN_MATCH_SCORE=0.35
RISK_MIN_QUERY_MARKET_TOKEN_OVERLAP=2
RISK_MIN_QUERY_MARKET_OVERLAP_TOKEN_LENGTH=5
RISK_MIN_ANCHOR_ENTITY_OVERLAP=1
RISK_ANCHOR_ENTITY_MAX_TOKENS=2
RISK_MAX_OPEN_POSITIONS_PER_ENTITY=1
RISK_MAX_ENTITY_OPEN_EXPOSURE_USD=50
RISK_MAX_TRADES_PER_ANALYSIS=1
RISK_MIN_TOP_CANDIDATE_SCORE_DELTA=0.05
RISK_MAX_BID_ASK_SPREAD=0.03
RISK_MAX_YES_ENTRY_SLIPPAGE=0.02
RISK_MAX_DAILY_EXPOSURE_USD=250
RISK_MAX_TRADE_SIZE_USD=50
RISK_MAX_LIQUIDITY_SHARE=0.02
RISK_BLOCK_ON_EXISTING_POSITION=true

PAPER_REQUIRE_RISK_APPROVAL=true
PAPER_AUTO_CLOSE_ENABLED=true
