PAPER_STOP_LOSS_DELTA=0.05
PAPER_MAX_HOLD_MINUTES=360
NEWS_RETRY_MAX_ATTEMPTS=3
NEWS_RETRY_BASE_DELAY_SECONDS=2.0
OPENAI_RETRY_MAX_ATTEMPTS=2
OPENAI_RETRY_BASE_DELAY_SECONDS=2.0
GAMMA_RETRY_MAX_ATTEMPTS=3
GAMMA_RETRY_BASE_DELAY_SECONDS=1.0

SCHEDULER_INTERVAL_MINUTES=15
